{
  "expo": {
    "name": "LUXE",
    "slug": "luxe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "luxe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f4ef"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luxe.marketplace",
      "config": {
        "usesNonExemptEncryption": false,
        "googleMapsApiKey": "AIzaSyBf0hycsxuNKRh94zf8A2HWTQOzSGkt44w"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f4ef"
      },
      "package": "com.luxe.marketplace",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBf0hycsxuNKRh94zf8A2HWTQOzSGkt44w"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LUXE to access your camera for QR scanning and product photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LUXE to access your photos for product images and avatars."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LUXE to use your location to autofill delivery addresses and pin map location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#535e2c"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
