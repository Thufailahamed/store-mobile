# Map from store/.env.local — use EXPO_PUBLIC_* (never copy server secrets)

# Supabase ← NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PayHere / orders API ← NEXT_PUBLIC_APP_URL
EXPO_PUBLIC_STORE_API_URL=http://localhost:3000

# Maps ← NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-public-key

# Locale ← NEXT_PUBLIC_DEFAULT_CURRENCY / NEXT_PUBLIC_DEFAULT_LOCALE
EXPO_PUBLIC_DEFAULT_CURRENCY=LKR
EXPO_PUBLIC_DEFAULT_LOCALE=en-LK

# Stripe ← NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (optional)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
