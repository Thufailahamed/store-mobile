# Map from store/.env.local — use EXPO_PUBLIC_* (never copy server secrets)

# Supabase ← NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LUXE Workers backend — Supabase is now DB+auth only. Mobile sends Bearer JWT
# to this URL via lib/api/delivery-api.ts (storeApiFetch wrapper).
EXPO_PUBLIC_STORE_API_URL=https://store-backend.thufailahamed627.workers.dev

# Maps ← NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-public-key

# Locale ← NEXT_PUBLIC_DEFAULT_CURRENCY / NEXT_PUBLIC_DEFAULT_LOCALE
EXPO_PUBLIC_DEFAULT_CURRENCY=LKR
EXPO_PUBLIC_DEFAULT_LOCALE=en-LK

# Stripe ← NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (optional)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# External courier integration (third-party delivery partner).
# Mirrors backend EXTERNAL_COURIER_ENABLED / INTERNAL_DELIVERY_PORTAL_VISIBLE
# so mobile can hide legacy (delivery) / (delivery-company) tabs and surface
# the external courier admin screens. Default false — opt-in per environment.
EXPO_PUBLIC_EXTERNAL_COURIER_ENABLED=false
EXPO_PUBLIC_INTERNAL_DELIVERY_PORTAL_VISIBLE=false
